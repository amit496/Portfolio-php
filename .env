# ========================================
# EMAIL CONFIGURATION FOR PORTFOLIO
# ========================================

# SMTP Settings (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail Address
SMTP_USER=gautamamit557@gmail.com

# Gmail App Password (NOT your regular password)
# To generate App Password:
# 1. Go to Google Account Settings
# 2. Security → 2-Step Verification (Enable it first)
# 3. App Passwords → Generate new app password
# 4. Select "Mail" and "Other (Custom name)"
# 5. Copy the 16-character password
SMTP_PASS=sfus dxoj gnac mscb

# From Name (Display name in emails)
FROM_NAME=Amit Gautam Portfolio

# ========================================
# IMPORTANT NOTES:
# ========================================
# 1. Never share this file publicly
# 2. Add .env to .gitignore
# 3. Use App Password, not regular Gmail password
# 4. Enable 2-Step Verification in Gmail first
# 5. Replace spaces in SMTP_PASS (xxxx xxxx xxxx xxxx format is OK)
# ========================================